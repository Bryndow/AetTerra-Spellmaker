<Window x:Class="FIO_zeitverteib.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FIO_zeitverteib"
        mc:Ignorable="d"
        Title="BrickWindow's Spellmaker: Redemption" Height="429" Width="737" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Button Name="btnClear" Content="Clear Sequence" Grid.Row="4" Click="btnClear_Click"/>
        <Button Name="btnSelFile" Grid.Column="1" Content="Select File" Grid.Row="4" Click="btnSelFile_Click"/>
        <Button Name="btnWrite" Grid.Column="2" Content="Write Data" Grid.Row="4" Click="btnWrite_Click"/>
        <Button Name="btnRead" Grid.Column="3" Content="Read Data" Grid.Row="4" Click="btnRead_Click"/>

        <Button Name="btnPassIn" Content="Pass In" Grid.Row="5" Click="btnPassIn_Click"/>
        <Button Name="btnTossFile" Grid.Column="1" Content="Toss File" Grid.Row="5" Click="btnTossFile_Click"/>
        <Button Name="btnExport" Grid.Column="2" Content="Export As GDScript" Grid.Row="5" Click="btnExport_Click"/>

        <GroupBox Header="Input" Grid.RowSpan="4" Grid.ColumnSpan="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <GroupBox Header="Name" Grid.ColumnSpan="2">
                    <TextBox Name="tbName" HorizontalAlignment="Stretch" TextWrapping="Wrap"/>
                </GroupBox>
                <GroupBox Grid.Column="2" Header="Base Name">
                    <TextBox Name="tbBaseName" TextWrapping="Wrap"/>
                </GroupBox>
                <GroupBox Grid.Column="2" Header="Properties" Grid.Row="1" Grid.RowSpan="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <CheckBox Name="cbUseBase" Content="Use Base" Grid.ColumnSpan="2"/>
                        <CheckBox Name="cbContinuous" Content="Infinte" Grid.Row="1" Grid.ColumnSpan="2"/>
                        <RadioButton Name="cbStateRegardless" Content="Irrelevent" Grid.Row="3" Grid.ColumnSpan="2" IsChecked="True"/>
                        <RadioButton Name="cbStateGround" Content="Ground Only" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"/>
                        <RadioButton Name="cbStateAir" Content="Air Only" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2"/>
                        <RadioButton Name="cbStateBoth" Content="Both Differing" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Grid.RowSpan="3"/>
                        <Label Content="States" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Padding="5,0,5,5" Grid.RowSpan="2"/>
                        <Label Content="Drain" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Padding="5,0,5,5" Grid.RowSpan="2"/>
                        <Slider Name="slDrain" Grid.ColumnSpan="4" HorizontalAlignment="Stretch" Grid.Row="2" VerticalAlignment="Top" Maximum="200" SmallChange="1" LargeChange="5" Value="50"/>
                        <CheckBox Name="cbUseTrgt" Grid.Column="2" Grid.ColumnSpan="2" Content="Use Target" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Grid>
                </GroupBox>
                <GroupBox Header="Sequence" Grid.Row="1" Grid.RowSpan="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Name="btnS_MIN_1" Grid.Column="6" Grid.Row="4" Content="" Click="btnS_MIN_1_Click"/>
                        <Button Name="btnS_MIN_2" Grid.Column="7" Grid.Row="4" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Click="btnS_MIN_2_Click"/>
                        <Button Name="btnS_MIN_3" Grid.Column="8" Grid.Row="6" Content="" Click="btnS_MIN_3_Click"/>
                        <Button Name="btnS_MIN_4" Grid.Column="7" Grid.Row="7" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Click="btnS_MIN_4_Click"/>
                        <Button Name="btnS_MIN_5" Grid.Column="6" Grid.Row="8" Content="" Click="btnS_MIN_5_Click"/>
                        <Button Name="btnS_MIN_6" Grid.Column="4" Grid.Row="7" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Click="btnS_MIN_6_Click"/>
                        <Button Name="btnS_MIN_7" Grid.Column="4" Grid.Row="6" Content="" Click="btnS_MIN_7_Click"/>
                        <Button Name="btnS_MIN_8" Grid.Column="4" Grid.Row="4" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Click="btnS_MIN_8_Click"/>

                        <Button Name="btnS_MID_1" Grid.Column="4" Grid.Row="2" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_1_Click"/>
                        <Button Name="btnS_MID_2" Grid.Column="7" Grid.Row="2" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_2_Click"/>
                        <Button Name="btnS_MID_3" Grid.Column="9" Grid.Row="4" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_3_Click"/>
                        <Button Name="btnS_MID_4" Grid.Column="9" Grid.Row="7" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_4_Click"/>
                        <Button Name="btnS_MID_5" Grid.Column="7" Grid.Row="9" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_5_Click"/>
                        <Button Name="btnS_MID_6" Grid.Column="4" Grid.Row="9" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_6_Click"/>
                        <Button Name="btnS_MID_7" Grid.Column="2" Grid.Row="7" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_7_Click"/>
                        <Button Name="btnS_MID_8" Grid.Column="2" Grid.Row="4" Content="" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="7" Background="#FFA0A0A0" Click="btnS_MID_8_Click"/>

                        <Button Name="btnS_MAX_1" Grid.Column="6" Grid.Row="1" Content="" Click="btnS_MAX_1_Click"/>
                        <Button Name="btnS_MAX_2" Grid.Column="10" Grid.Row="2" Content="" Click="btnS_MAX_2_Click"/>
                        <Button Name="btnS_MAX_3" Grid.Column="11" Grid.Row="6" Content="" Click="btnS_MAX_3_Click"/>
                        <Button Name="btnS_MAX_4" Grid.Column="10" Grid.Row="10" Content="" Click="btnS_MAX_4_Click"/>
                        <Button Name="btnS_MAX_5" Grid.Column="6" Grid.Row="11" Content="" Click="btnS_MAX_5_Click"/>
                        <Button Name="btnS_MAX_6" Grid.Column="2" Grid.Row="10" Content="" Click="btnS_MAX_6_Click"/>
                        <Button Name="btnS_MAX_7" Grid.Column="1" Grid.Row="6" Content="" Click="btnS_MAX_7_Click"/>
                        <Button Name="btnS_MAX_8" Grid.Column="2" Grid.Row="2" Content="" Click="btnS_MAX_8_Click"/>
                    </Grid>
                </GroupBox>
                <ListView Name="debug_curentSeqDisplay" Grid.Column="1" Grid.Row="1" Grid.RowSpan="3" d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>
        <GroupBox Header="Output" Grid.Column="3" Grid.RowSpan="4">
            <ListView Name="debug_showSpells" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
    </Grid>
</Window>
